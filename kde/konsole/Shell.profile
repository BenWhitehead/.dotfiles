[Appearance]
AntiAliasFonts=false
BoldIntense=false
ColorScheme=Linux
Font=Adobe Courier,11,-1,5,50,0,0,0,0,0

[General]
Icon=utilities-terminal
LocalTabTitleFormat=%D : %n
MenuIndex=1
Name=Shell
Parent=FALLBACK/
RemoteTabTitleFormat=%h : %u
SaveGeometryOnExit=false
ShowNewAndCloseTabButtons=false
TabBarMode=1
TabBarPosition=1

[Keyboard]
KeyBindings=default

[Scrolling]
HistorySize=100000
